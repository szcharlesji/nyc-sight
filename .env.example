# Spark Sight — NIM Endpoint Configuration
# Copy to .env and update with your GB10 IP address.
NIM_HOST=<GB10_IP>

# Cosmos Reason2-8B (Ambient Agent — VLM)
COSMOS_NIM_URL=http://<GB10_IP>:8000/v1
COSMOS_MODEL=nvidia/cosmos-reason2-8b

# Nemotron-3-Nano-30B (Planning Agent — LLM)
NEMOTRON_NIM_URL=http://<GB10_IP>:8005/v1
NEMOTRON_MODEL=nemotron-nano

# Parakeet 1.1B RNNT Multilingual (Speech-to-Text)
PARAKEET_NIM_URL=http://<GB10_IP>:9000/v1
PARAKEET_MODEL=parakeet-1.1b-rnnt

# Magpie TTS Multilingual (Text-to-Speech)
MAGPIE_NIM_URL=http://<GB10_IP>:9001/v1
MAGPIE_MODEL=magpie-tts
MAGPIE_VOICE=English-US.Female-1
