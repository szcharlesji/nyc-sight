# Spark Sight — Service Configuration
# Copy to .env and update with your service IPs.

# ── Speech Services (Docker) ─────────────────────────────────
# Kokoro-82M TTS (OpenAI-compatible)
TTS_BASE_URL=http://<DOCKER_HOST>:8880/v1
TTS_MODEL=kokoro
TTS_VOICE=af_bella

# Parakeet-EOU-120M Streaming ASR (WebSocket)
PARAKEET_WS_URL=ws://<DOCKER_HOST>:3030/asr

# ── NIM Agents (GB10/DGX) ────────────────────────────────────
# Cosmos Reason2-8B (Ambient Agent — VLM)
COSMOS_NIM_URL=http://<GB10_IP>:8000/v1
COSMOS_MODEL=nvidia/cosmos-reason2-8b

# Nemotron-3-Nano-30B (Planning Agent — LLM)
NEMOTRON_NIM_URL=http://<GB10_IP>:8005/v1
NEMOTRON_MODEL=nemotron-nano
