# =============================================================================
# NIM Stack Environment Configuration — DGX Spark (GB10, SM121, 128GB)
#
# This file is the single source of truth for all tunable parameters.
# Docker Compose interpolates these automatically when invoked from start.sh.
#
# NOTE: Docker Compose .env files do NOT expand ${HOME} or ~.
#       start.sh resolves paths before invoking compose.
# =============================================================================

# === NGC Authentication ===
# Required. Obtain from https://org.ngc.nvidia.com/setup
NGC_API_KEY=

# === Host User ID ===
# Used by Cosmos container for NIM cache write permissions.
# start.sh overrides this to $(id -u) automatically.
# Named HOST_UID (not UID) to avoid readonly shell builtin conflict.
HOST_UID=1000

# === Shared NIM Cache ===
# All four containers share this cache directory.
# First-run downloads can be 50GB+; preserve across restarts.
LOCAL_NIM_CACHE=~/.cache/nim

# =============================================================================
# Nemotron-3-Nano-30B (LLM) — ~44GB GPU (27GB weights + 17GB KV cache)
# =============================================================================
NEMOTRON_IMAGE=nvcr.io/nim/nvidia/model-free-nim:2.0.2
# Host directory containing the model weights folder
NEMOTRON_MODEL_PATH=~/Downloads/models/llm
# Subdirectory name within NEMOTRON_MODEL_PATH (the actual model folder)
NEMOTRON_MODEL_SUBDIR=nvidia--NVIDIA-Nemotron-3-Nano-30B-A3B-NVFP4
NEMOTRON_PORT=8005
# KV cache fraction of remaining GPU memory after weights are loaded.
# 0.35 = ~17GB on GB10 with this model. Higher risks OOM when other NIMs load.
NEMOTRON_KVCACHE_PERCENT=0.35
# Max context window. 32768 is the sweet spot for Nano-30B on 128GB shared GPU.
# Default (131072) would blow the KV cache budget.
NEMOTRON_MAX_MODEL_LEN=32768
NEMOTRON_MODEL_NAME=nemotron-nano

# =============================================================================
# Cosmos-Reason2-8B (VLM) — ~44GB GPU (36GB weights + 8GB KV cache)
# =============================================================================
COSMOS_IMAGE=nvcr.io/nim/nvidia/cosmos-reason2-8b:1.6.0
COSMOS_PORT=8000
COSMOS_KVCACHE_PERCENT=0.35
# Max context for Cosmos. Default (262144) requires 36GB KV cache alone — fatal.
# 16384 keeps KV cache at ~8GB.
COSMOS_MAX_MODEL_LEN=16384
# Force bf16 model profile. FP8 produces numerically incorrect (garbage) output
# on SM121 / GB10. This hash selects the bf16 profile explicitly.
COSMOS_BF16_PROFILE=3266ed3ec2297386d2e4a94e6c84a5b0ba92244f787c538f33577c4c78c5aef2

# =============================================================================
# Magpie TTS Multilingual — ~11GB GPU (batch_size=8 default profile)
# =============================================================================
MAGPIE_IMAGE=nvcr.io/nim/nvidia/magpie-tts-multilingual:latest
MAGPIE_HTTP_PORT=9000
MAGPIE_GRPC_PORT=50051

# =============================================================================
# Parakeet 1.1B RNNT Multilingual ASR — ~2-4GB GPU
# =============================================================================
PARAKEET_IMAGE=nvcr.io/nim/nvidia/parakeet-1-1b-rnnt-multilingual:latest
PARAKEET_HTTP_PORT=9001
PARAKEET_GRPC_PORT=50052
